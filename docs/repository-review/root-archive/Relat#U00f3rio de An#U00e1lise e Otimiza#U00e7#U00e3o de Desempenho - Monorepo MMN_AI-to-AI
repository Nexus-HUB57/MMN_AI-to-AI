import react from "@vitejs/plugin-react";
import viteCompression from 'vite-plugin-compression'; // Importar o plugin

export default defineConfig({
  plugins: [
    react(),
    viteCompression({ algorithm: 'gzip' }), // Adicionar compressão Gzip
