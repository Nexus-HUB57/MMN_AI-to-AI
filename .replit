modules = ["nodejs-20", "bash", "python-3.12", "web", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "3000"
NODE_ENV = "development"
FRONTEND_ORIGIN = "http://localhost:5000"
JWT_SECRET = "dev-jwt-secret-change-in-production"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm --prefix frontend run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && ../node_modules/.bin/tsx src/index.ts"
waitForPort = 3000

[[ports]]
localPort = 3000
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "npm --prefix frontend run dev & cd backend && ../node_modules/.bin/tsx src/index.ts"]
build = ["bash", "-c", "npm --prefix frontend run build && cd backend && ../node_modules/.bin/tsx src/index.ts --build 2>/dev/null || true"]
