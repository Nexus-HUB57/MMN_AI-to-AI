{
  "academia_version": "1.1.0",
  "schema_version": "1.0",
  "last_updated": "2026-06-02",
  "description": "Manifesto de sincronização entre a Academ'IA e o runtime dos agentes. Mapeia níveis de conhecimento → bundle de skills → permissões SHO. Carregado pelo CentralOrchestrator durante o bootstrap.",
  "agent_runtime": "backend/src/agentic",
  "skill_dispatch": "backend/src/agentic/skills/dispatcher.ts",
  "judge_endpoint": "backend/src/agentic/judge/judgeRevisor.ts",
  "trirf_mapping": {
    "fundamental": {
      "level": 1,
      "status_required": "cadastrado",
      "skills_entitlement": [
        "copywriter-persuasivo",
        "analytics-reporter"
      ],
      "sh": {
        "confidenceThreshold": 0.70,
        "autoApprove": true,
        "riskLimitBRL": 30,
        "maxDailyMessages": 50
      },
      "courses_completed_required": [
        "cursos/fundamental/00-boas-vindas.md",
        "cursos/fundamental/01-entendendo-ioaid.md",
        "cursos/fundamental/02-sistema-sho.md",
        "cursos/fundamental/03-painel-afiliado.md"
      ]
    },
    "agente": {
      "level": 2,
      "status_required": "primeiro_ciclo_ativo",
      "skills_entitlement": [
        "audience-segmenter",
        "auto-publisher",
        "judge-revisor",
        "follow-up-strategist"
      ],
      "sh": {
        "confidenceThreshold": 0.75,
        "autoApprove": true,
        "riskLimitBRL": 50,
        "maxDailyMessages": 500
      },
      "courses_completed_required": [
        "cursos/agente/00-primeiro-agente.md",
        "cursos/agente/01-skills-essenciais.md",
        "cursos/agente/02-disparo-whatsapp.md",
        "cursos/agente/03-judge-revisor.md"
      ]
    },
    "master": {
      "level": 3,
      "status_required": "tres_ciclos_concluidos",
      "skills_entitlement": [
        "funnel-architect",
        "lifecycle-orchestrator",
        "ab-test-designer",
        "roi-attributor",
        "pricing-optimizer",
        "cohort-analyzer"
      ],
      "sh": {
        "confidenceThreshold": 0.80,
        "autoApprove": true,
        "riskLimitBRL": 200,
        "maxDailyMessages": 5000
      },
      "courses_completed_required": [
        "cursos/master/00-otimizacao-conversao.md",
        "cursos/master/01-funis-lifecycle.md",
        "cursos/master/02-ab-test-judge.md",
        "cursos/master/03-coortes-churn.md"
      ]
    },
    "elite": {
      "level": 4,
      "status_required": "top_10_percent",
      "skills_entitlement": [
        "white-label-sync",
        "federation-gate",
        "auto-prompt-tuner",
        "bridge-legacy",
        "high-ticket-b2b"
      ],
      "sh": {
        "confidenceThreshold": 0.85,
        "autoApprove": true,
        "riskLimitBRL": 1000,
        "maxDailyMessages": 50000
      },
      "courses_completed_required": [
        "cursos/elite/00-blueprints-elite.md",
        "cursos/elite/01-multi-tenant-whitelabel.md",
        "cursos/elite/02-federacao-agentes.md"
      ],
      "additional_requirements": [
        "NDA_assigned: true",
        "lib_nexus_contributions: >= 1",
        "mentored_count: >= 3"
      ]
    }
  },
  "lab_nexus_to_skill_mapping": {
    "Lab-Nexus/tools/copy/01-headline-persuasiva.md": "copywriter-persuasivo",
    "Lab-Nexus/tools/copy/02-email-frio.md": "cold-emailer",
    "Lab-Nexus/tools/copy/04-whatsapp-persuasivo.md": "copywriter-persuasivo",
    "Lab-Nexus/tools/copy/13-disparo-sms-conversacional.md": "sms-conversacional",
    "Lab-Nexus/tools/marketing/01-planejador-editorial.md": "auto-publisher",
    "Lab-Nexus/tools/marketing/02-segmentacao-rfm.md": "audience-segmenter",
    "Lab-Nexus/tools/marketing/09-plano-conteudo-90-dias.md": "plano-conteudo-90d",
    "Lab-Nexus/tools/analytics/02-comparador-taxas-conversao.md": "roi-attributor",
    "Lab-Nexus/tools/analytics/04-atribuicao-multitouch.md": "roi-attributor",
    "Lab-Nexus/tools/analytics/05-coorte-churn.md": "cohort-analyzer",
    "Lab-Nexus/tools/automation/01-webhooks-payload.md": "webhook-router",
    "Lab-Nexus/tools/automation/05-backup-criptografado.md": "backup-encryption"
  },
  "sync_events": {
    "on_course_completed": "agents.skills_entitlement += level_up",
    "on_certification_achieved": "agents.certifications.push(cert) + audit_log",
    "on_level_promoted": "sh.confidenceThreshold = level_default + audit_log",
    "on_skill_added_in_lab": "skill_manifest.json updated + dispatcher.ts registered"
  }
