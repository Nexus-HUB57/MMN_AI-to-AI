#!/usr/bin/env sh
set -e

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

pattern="^(build|chore|ci|docs|feat|fix|perf|refactor|style|test|wf)(\([a-zA-Z0-9._/-]+\))?(!)?: .+$"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "❌ Formato de commit inválido."
  echo ""
  echo "📋 Conventional Commits:" 
  echo "   <type>(<scope>)?(!)?: <description>"
  echo ""
  echo "📝 Tipos permitidos:"
  echo "   build, chore, ci, docs, feat, fix, perf, refactor, style, test, wf"
  echo ""
  echo "📖 Exemplos:"
  echo "   feat(auth): adiciona autenticação Firebase"
  echo "   fix(api): corrige timeout de endpoint tRPC"
  echo "   docs(readme): atualiza guia de instalação"
  echo ""
  exit 1
fi

echo "✅ Commit message validado"
