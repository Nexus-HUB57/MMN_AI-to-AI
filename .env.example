# =============================================================================
# Nexus Affil'IA'te — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA commite o .env com segredos reais!
# =============================================================================

# =============================================================================
# Configuração Geral
# =============================================================================
NODE_ENV=development
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,https://oneverso.com.br,https://www.oneverso.com.br,https://api.oneverso.com.br

# =============================================================================
# Admin Auth (obrigatório para login admin via backend)
# Gere com: node -e "console.log(require('crypto').createHash('sha256').update('seu_email').digest('hex'))"
# =============================================================================
ADMIN_SESSION_SECRET=gere_uma_chave_secreta_com_crypto_random_32bytes
ADMIN_EMAIL_SHA256=sha256_do_email_autorizonado
ADMIN_PASSWORD_SHA256=sha256_da_senha_autorizada

# =============================================================================
# Database — Postgres (Render Managed Postgres)
# Obtenha em: Render Dashboard → Postgres → Connections
# =============================================================================
DATABASE_URL=postgres://usuario:senha@host:5432/database

# =============================================================================
# Cache — Redis (opcional; standalone funciona sem)
# Obtenha em: Render Dashboard → Redis → Connection Info
# =============================================================================
REDIS_URL=redis://host:6379

# =============================================================================
# LLM — OpenAI API (opcional)
# O judge cai em heurística se ausente.
# Obtenha em: platform.openai.com/api-keys
# =============================================================================
OPENAI_API_KEY=sk-...

# =============================================================================
# Analytics Cron (opcional)
# =============================================================================
ENABLE_ANALYTICS_CRON=true
ANALYTICS_CRON_HOURS=6

# =============================================================================
# WhatsApp Business API (dispatcher real — opcional)
# Obtenha em: business.facebook.com → Meta Business Suite
# =============================================================================
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_DEFAULT_RECIPIENT=

# =============================================================================
# Resend Email (dispatcher real — opcional)
# Obtenha em: resend.com/api-keys
# =============================================================================
RESEND_API_KEY=
RESEND_FROM=contato@oneverso.com.br
RESEND_DEFAULT_RECIPIENT=

# =============================================================================
# Facebook Pages (dispatcher real — opcional)
# =============================================================================
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=

# =============================================================================
# Hotmart API (integração marketplace — opcional)
# Obtenha em: developer.hotmart.com
# =============================================================================
HOTMART_CLIENT_ID=
HOTMART_CLIENT_SECRET=
HOTMART_TOKEN_URL=https://api-sec-vlc.hotmart.com/security/oauth/token
HOTMART_API_BASE=https://developers.hotmart.com

# =============================================================================
# Shopee Afiliados (integração marketplace — opcional)
# =============================================================================
SHOPEE_AFFILIATE_PROFILE_NAME=Nexus SaaS
SHOPEE_AFFILIATE_USERNAME=

# =============================================================================
# Firebase Auth Admin (servidor — opcional)
# Obtenha em: Firebase Console → Project Settings → Service accounts
# =============================================================================
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# =============================================================================
# Firebase Client SDK (frontend — variáveis build-time com prefixo VITE_)
# Obtenha em: Firebase Console → Project Settings → Your apps → Web app
# =============================================================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# =============================================================================
# Frontend build-time
# =============================================================================
VITE_TRPC_URL=http://localhost:3000/api/trpc
VITE_API_URL=http://localhost:5173
