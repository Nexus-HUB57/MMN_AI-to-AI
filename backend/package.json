{
  "name": "@mmn/backend",
  "version": "1.0.0",
  "private": true,
  "description": "Nexus Affil'IA'te IOAID — Backend (Node.js + tRPC + Drizzle ORM + MySQL + Redis/BullMQ + Genkit + LangChain + Ollama + Unstructured.io + Mastra)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --platform=node --bundle --format=cjs --packages=external --outfile=dist/index.js",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "genkit:dev": "tsx watch src/genkit/index.ts",
    "genkit:start": "tsx src/genkit/index.ts",
    "worker:content": "tsx src/workers/contentGenerationWorker.ts",
    "worker:commissions": "tsx src/workers/commissionProcessingWorker.ts",
    "worker:marketplace": "tsx src/workers/marketplaceSyncWorker.ts",
    "worker:orders": "tsx src/workers/orderProcessingWorker.ts",
    "db:generate": "drizzle-kit generate --config=../infra/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=../infra/drizzle.config.ts",
    "db:push": "drizzle-kit push --config=../infra/drizzle.config.ts",
    "build:workers": "mkdir -p dist/workers && esbuild src/workers/contentGenerationWorker.ts --platform=node --bundle --format=cjs --packages=external --outfile=dist/workers/contentGenerationWorker.js && esbuild src/workers/commissionProcessingWorker.ts --platform=node --bundle --format=cjs --packages=external --outfile=dist/workers/commissionProcessingWorker.js && esbuild src/workers/marketplaceSyncWorker.ts --platform=node --bundle --format=cjs --packages=external --outfile=dist/workers/marketplaceSyncWorker.js && esbuild src/workers/orderProcessingWorker.ts --platform=node --bundle --format=cjs --packages=external --outfile=dist/workers/orderProcessingWorker.js",
    "build:production": "npm run build && npm run build:workers"
  },
  "dependencies": {
    "@genkit-ai/core": "^1.28.0",
    "@genkit-ai/googleai": "^1.28.0",
    "@langchain/core": "^0.3.58",
    "@sentry/node": "^8.55.2",
    "@trpc/server": "^11.0.0",
    "abort-controller": "^3.0.0",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.7.9",
    "bullmq": "^5.28.2",
    "cookie": "^1.0.2",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "firebase-admin": "^13.10.0",
    "formdata-node": "^4.4.1",
    "genkit": "^1.28.0",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "langchain": "^0.3.0",
    "nanoid": "^5.0.9",
    "node-cron": "^4.0.3",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.10.1",
    "openai": "^4.77.0",
    "pg": "^8.21.0",
    "pgvector": "^0.2.0",
    "sharp": "^0.33.5",
    "superjson": "^2.2.2",
    "uuid": "^11.1.0",
    "whatwg-url": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie": "^0.6.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "drizzle-kit": "^0.30.0",
    "esbuild": "^0.24.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
