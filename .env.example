# Database
DATABASE_URL=mysql://root:password@localhost:3306/mmn_ai
MYSQL_ROOT_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379

# AI Models
OPENAI_API_KEY=your_openai_api_key_here

# Auth
JWT_SECRET=your_jwt_secret_here

# App
PORT=3000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,https://oneverso.com.br
PUBLIC_DIR=./public

# =============================================================================
# Plataformas parceiras (Nexus SaaS)
# Em produção, defina apenas no backend/.env (NÃO commitar).
# =============================================================================

# Shopee Afiliados
SHOPEE_AFFILIATE_PROFILE_NAME="Nexus SaaS"
SHOPEE_AFFILIATE_USERNAME=
SHOPEE_AFFILIATE_ID=
SHOPEE_LOGIN_EMAIL=
SHOPEE_LOGIN_PASSWORD=

# Hotmart API
HOTMART_CLIENT_ID=
HOTMART_CLIENT_SECRET=
HOTMART_BASIC_AUTH=
HOTMART_TOKEN_URL=https://api-sec-vlc.hotmart.com/security/oauth/token
HOTMART_API_BASE=https://developers.hotmart.com

# =============================================================================
# PIX — Epic 10.2 (Sprint 10.1)
# Configure PIX_SANDBOX=false e PIX_KEY em produção para habilitar pagamentos reais.
# =============================================================================

# Chave PIX do recebedor (CPF, CNPJ, email, telefone +55 ou EVP/UUID)
PIX_KEY=

# Nome do recebedor (máx 25 caracteres, sem acentos)
PIX_RECEIVER_NAME=MMN AI-to-AI

# Cidade do recebedor (máx 15 caracteres, sem acentos)
PIX_RECEIVER_CITY=SAO PAULO

# true = modo sandbox (não exige PSP real); false = produção
PIX_SANDBOX=true

# =============================================================================
# Firebase Auth — Epic 10.3 (Sprint 10.1)
# Preencha com as credenciais da conta de serviço do Firebase Admin SDK.
# Obtenha em: Firebase Console → Project Settings → Service accounts
# =============================================================================

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Chave privada (substitua \n reais por \\n na string)
FIREBASE_PRIVATE_KEY=
