{
  "name": "@mmn/backend",
  "version": "1.0.0",
  "private": true,
  "description": "Nexus AfilIAte-AI — Backend (Node.js + tRPC + Drizzle ORM + MySQL + Redis/BullMQ + Genkit)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "genkit:dev": "tsx watch src/genkit/index.ts",
    "genkit:start": "tsx src/genkit/index.ts",
    "worker:content": "tsx src/workers/contentGenerationWorker.ts",
    "worker:commissions": "tsx src/workers/commissionProcessingWorker.ts",
    "worker:marketplace": "tsx src/workers/marketplaceSyncWorker.ts",
    "worker:orders": "tsx src/workers/orderProcessingWorker.ts",
    "db:generate": "drizzle-kit generate --config=../infra/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=../infra/drizzle.config.ts",
    "db:push": "drizzle-kit push --config=../infra/drizzle.config.ts"
  },
  "dependencies": {
    "@genkit-ai/core": "^1.0.0",
    "@genkit-ai/googleai": "^1.0.0",
    "@trpc/server": "^11.0.0",
    "axios": "^1.7.7",
    "bullmq": "^5.21.2",
    "cookie": "^1.0.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.1",
    "genkit": "^1.0.0",
    "ioredis": "^5.4.1",
    "jose": "^5.9.4",
    "mysql2": "^3.22.3",
    "nanoid": "^5.1.11",
    "openai": "^4.68.0",
    "superjson": "^2.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie": "^0.6.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.4",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
